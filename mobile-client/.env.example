# Phantom Portal (https://phantom.com/portal) — App ID for @phantom/react-native-sdk
#
# Redirect URL registered in Portal (must match src/config/phantom.ts phantomAuthRedirectUrl):
#   solfundme://auth/callback
#
# Must match:
#   - app.json: expo.scheme, ios.scheme, android.scheme → "solfundme"
#   - src/config/phantom.ts: PHANTOM_SCHEME + path //auth/callback
#
# Copy to .env and set your App ID from Portal.
EXPO_PUBLIC_PHANTOM_APP_ID=
